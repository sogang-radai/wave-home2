{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake: configure (Debug)",
            "type": "shell",
            "command": "cmake -B build -DCMAKE_BUILD_TYPE=Debug -DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "cmake: build",
            "type": "shell",
            "command": "cmake --build build",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "cmake: configure (Debug)",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "cmake: build test-ir",
            "type": "shell",
            "command": "cmake --build build --target test-ir",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "cmake: configure (Debug)",
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "cmake: build test-llm",
            "type": "shell",
            "command": "cmake --build build --target test-llm",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "cmake: configure (Debug)",
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "npm: build frontend",
            "type": "shell",
            "command": "./scripts/build-front.sh",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "cmake: build wave-server",
            "type": "shell",
            "command": "cmake --build build --target wave-server",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "cmake: configure (Debug)",
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}
