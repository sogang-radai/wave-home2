{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug test-ir (--list)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bin/test/test-ir",
            "args": [
                "--list"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "cmake: build test-ir"
        },
