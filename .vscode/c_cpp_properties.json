{
    "configurations": [
        {
            "name": "Linux",
            "compileCommands": "${workspaceFolder}/compile_commands.json",
            "cStandard": "c17",
            "cppStandard": "c++23",
            "intelliSenseMode": "linux-gcc-x64",
            "includePath": [
                "${workspaceFolder}/src/wave-server",
                "${workspaceFolder}/thirdparty/drogon/lib/inc",
                "${workspaceFolder}/thirdparty/drogon/trantor",
                "${workspaceFolder}/thirdparty/ncnn/src"
            ],
            "browse": {
                "path": [
                    "${workspaceFolder}",
                    "${workspaceFolder}/src",
                    "${workspaceFolder}/thirdparty/drogon",
                    "${workspaceFolder}/thirdparty/ncnn"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        }
    ],
    "version": 4
}
